{
  "manifest_version": 3,
  "name": "Higgsfield Prompt Extender & Batch Generator",
  "version": "1.2.0",
  "description": "Optimize the Higgsfield prompt box layout, resize sidebars, and run sequential batch video generations.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.higgsfield.ai/*"
  ],
  "action": {
    "default_title": "Higgsfield Batch"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.higgsfield.ai/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.higgsfield.ai/*"
      ],
      "js": [
        "inject.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
